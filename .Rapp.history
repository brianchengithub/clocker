ship1 = read_excel(filepath,2)#
ship2 = read_excel(filepath,3)#
#
# Ensure sorted by 'queue-seq'#
ship1 = ship1[order(ship1$queue_seq),]#
ship2 = ship2[order(ship2$queue_seq),]#
#
# Add shipment wave#
ship1$ship = 1#
ship2$ship = 2#
#
# Assign Rows#
ship1$boxrow = rep_len(LETTERS[1:8], nrow(ship1))#
ship2$boxrow = rep_len(LETTERS[1:8], nrow(ship2))#
#
# Assign Columns#
ship1$boxcol = rep_len(rep(1:12, each=8), nrow(ship1))#
ship2$boxcol = rep_len(rep(1:12, each=8), nrow(ship2))#
#
# Assign box position#
ship1$boxpos = paste0(ship1$boxrow, ship1$boxcol)#
ship2$boxpos = paste0(ship2$boxrow, ship2$boxcol)#
#
# Denote box (Fill in actual box number manually)#
ship1$box = ceiling(ship1$queue_seq/96)#
ship2$box = ceiling(ship2$queue_seq/96)#
#
# Concatenate#
names(ship1) <- names(ship2)#
all = rbind(ship1, ship2)#
#
# Fix notes (contains comma...messes up CSV)#
all$notes = ifelse( is.na(all$NOTE), NA, "tube empty (validate and discard)")#
all = all[,-8]#
#
# Output into a single CSV#
write.csv(all, "/Users/bc/Downloads/combined-samplesheet-Sutter-ET0782_06-13-2025.csv", row.names=F, quote=F)
write.csv(all, "/Users/bc/Downloads/combined-samplesheet-Sutter-ET0782_06-13-2025.csv", row.names=F, quote=F, na="")

#-----------------------------------------------------------------#
## 1. Setup: Load Libraries  #
#-----------------------------------------------------------------#
library(sesame)#
library(GenomicRanges)#
library(tidyverse)#
library(readr)#
library(stringr)#
library(readxl)#
library(RColorBrewer) #
library(progressr)    #
library(progress)     #
library(gridExtra)    #
library(grid)#
#
# --- Configure progress bars ---#
handlers(global = TRUE) #
handlers("progress")#
#-----------------------------------------------------------------#
## 2. Define Your Input/Output Paths (Updated)#
#-----------------------------------------------------------------#
# !!! IMPORTANT: Update this path to your directory#
sdf_directory <- "/Users/bc/Documents/gestalt/analysis/sdfs/" #
#
# Define the name for the final combined PDF#
output_pdf <- "/Users/bc/Desktop/GESTALT-Y-intensities.pdf"#
#
# !!! IMPORTANT: Update this path to your LINKER file directory#
linker_directory <- "/Users/bc/Documents/gestalt/"#
#
# Load Phenotype file#
pheno = readxl::read_excel("/Users/bc/Documents/gestalt/pheno/Gestalt Demographics.xlsx",1, skip=1)#
pheno = as.data.frame(pheno)#
names(pheno) = c("Donor", "DATE", "Age", "Sex", "BMI")#
#-----------------------------------------------------------------#
## 3. Load and Assemble Linker Key  #
#-----------------------------------------------------------------#
#
message("Finding and assembling linker files...")#
#
# Find all files matching the "samples.*.txt" pattern#
linker_file_paths <- list.files(#
  path = linker_directory,#
  pattern = "^samples\\..*\\.txt$", # Regex: starts with "samples." and ends with ".txt"#
  full.names = TRUE,#
  recursive = TRUE#
)#
#
if (length(linker_file_paths) == 0) {#
  stop(paste("No linker files matching 'samples.*.txt' found in:", linker_directory))#
} else {#
  message(paste("Found", length(linker_file_paths), "linker files. Reading and combining..."))#
}#
#
# Read and combine linker files#
# "c" = character#
# .default = "_" tells read_tsv to "skip all other columns"#
#
linker_df <- purrr::map_dfr(linker_file_paths, ~ readr::read_tsv(#
  .x, #
  col_types = cols(#
    Fname = "c", #
    Donor = "c", #
    .default = "_"  # unnecessary columns (inconsistencies lead to errors)#
  ), #
  show_col_types = FALSE#
))#
linker_df <- linker_df %>%#
  dplyr::distinct(Fname, .keep_all = TRUE) %>%    # Keep unique Fname mappings#
  mutate( Donor = tolower(str_remove_all(Donor, "-")) ) %>%   # Remove hyphens and convert to lowercase#
  select(Fname, Donor)  # Keep only desired columns#
#
message(paste("Linker key assembled with", nrow(linker_df), "unique Samplename-to-Donor mappings."))#
# Tidy phenotype file (containing sex data)#
sex_df = pheno %>%#
		dplyr::select(Donor, Sex) %>%#
		dplyr::filter(Sex %in% c("M", "F")) %>%#
		mutate( Donor = tolower(str_remove_all(Donor, "-")) ) %>%   # Remove hyphens and convert to lowercase#
		dplyr::distinct(Donor, .keep_all = TRUE) #
#-----------------------------------------------------------------#
## 4. Manifest & Region Prep (Restored to Original)#
#-----------------------------------------------------------------#
#
# Download array manifest#
url <- "https://github.com/zhou-lab/InfiniumAnnotationV1/raw/main/Anno/EPIC/EPIC.hg19.manifest.tsv.gz"#
manifest <- readr::read_tsv(url, show_col_types = FALSE)#
#
manifest <- manifest[!is.na(manifest$CpG_beg) & !is.na(manifest$CpG_end),]#
manifest <- manifest %>%#
  dplyr::filter(grepl("^chr[0-9XY]+$", CpG_chrm))#
manifest_gr <- GRanges(#
  seqnames = manifest$CpG_chrm,#
  ranges = IRanges(start = manifest$CpG_beg, end = manifest$CpG_end),#
  probeID = manifest$Probe_ID#
)#
#
# Define genomic regions #
y_region_gr <- GRanges(#
  seqnames = "chrY",#
  ranges = IRanges(start = 2694521, end = 59034049)#
)#
overlaps_y <- findOverlaps(manifest_gr, y_region_gr)#
y_region_probes <- manifest_gr[queryHits(overlaps_y)]$probeID#
#
autosomal_chroms <- paste0("chr", 1:22)#
autosomal_probes <- manifest_gr[seqnames(manifest_gr) %in% autosomal_chroms]$probeID#
#
message("Manifest and probe regions defined manually.")#
#-----------------------------------------------------------------#
## 5. Iterative Processing (SDFs) -- STABLE VERSION#
#-----------------------------------------------------------------#
#
message("Starting iterative processing of SDF files...")#
#
file_paths <- list.files(#
  path = sdf_directory,#
  pattern = "^sdfs_.*\\.RDS$",#
  full.names = TRUE#
)#
#
# --- DEBUG ---#
if (length(file_paths) > 2) {#
  message("--- DEBUG: Limiting analysis to 2 RDS files. ---")#
  file_paths <- file_paths[1:2]	#
}#
# ---#
#
# Check that probe lists from Section 4 exist#
if (!exists("autosomal_probes") || !exists("y_region_probes")) {#
  stop("Error: 'autosomal_probes' or 'y_region_probes' not found. Please re-run Section 4.")#
}#
all_results_list <- list()#
#
for (file_path in file_paths) {#
  filename <- basename(file_path)#
  dataset_name <- gsub("^sdfs_|.RDS$", "", filename)#
  message(paste("Processing dataset:", dataset_name, "..."))#
  sdf.list <- readRDS(file_path)#
  # --- FIX: Removed the with_progress() wrapper ---#
  results_df <- purrr::map_dfr(sdf.list, ~{#
    # Removed the p() call#
    sdf <- .x#
    # Get Karyotype  #
    sset <- tryCatch(#
      sesame::openSesame(sdf),#
      error = function(e) { return(NULL) }#
    )#
    inferred_sex = if (is.null(sset)) NA_character_ else sesame::inferSex(sset)#
    # Compute intensities#
    total_intensity <- totalIntensities(sdf)#
    if (length(total_intensity) == 0) {#
      return(data.frame(#
        median_y = NA_real_,#
        median_auto = NA_real_,#
        standardized_y = NA_real_,#
        inferred_sex = inferred_sex#
      ))#
    }#
    y_intensities <- total_intensity[names(total_intensity) %in% y_region_probes]#
    median_y_intensity <- median(y_intensities, na.rm = TRUE)#
    auto_intensities <- total_intensity[names(total_intensity) %in% autosomal_probes]#
    median_auto_intensity <- median(auto_intensities, na.rm = TRUE)#
    standardized_y <- median_y_intensity / median_auto_intensity#
    data.frame(#
      median_y = median_y_intensity,#
      median_auto = median_auto_intensity,#
      standardized_y = standardized_y,#
      inferred_sex = inferred_sex#
    )#
  }, .id = "sample_name") # This .id is the 'Fname'#
  # --- END FIX ---#
  # Add the dataset name#
  results_df$dataset <- dataset_name#
  all_results_list[[dataset_name]] <- results_df#
}#
#
message("All SDF files processed. Combining results...")#
#-----------------------------------------------------------------#
## 6. Combine, Link, and Prepare for Plotting  #
#-----------------------------------------------------------------#
#
# Combine all results from the list into one big data frame#
all_results_df <- dplyr::bind_rows(all_results_list)#
#
# Join the intensity results with the linker file#
all_results_linked <- all_results_df %>%#
  dplyr::left_join(linker_df, by = c("sample_name" = "Fname"))#
# Join with Sex data (from your pheno file)#
all_results_linked = all_results_linked %>%#
  dplyr::left_join(sex_df, by = c("Donor" = "Donor"))#
# 1. Sort order by Donor mean intensity (for Plot 2)#
onor_order <- all_results_linked %>%#
  group_by(Donor) %>% #
  summarize(mean_y = mean(standardized_y, na.rm = TRUE)) %>%#
  # Donors with all NA will have mean_y = NaN. This sorts them to one end.#
  arrange(mean_y) %>%#
  pull(Donor) #
#
# 2. Apply this new order to the Donor column by converting it to a factor#
# This factor is applied to the *pre-filtered* data#
all_results_linked$Donor_sorted <- factor(#
  all_results_linked$Donor, #
  levels = donor_order#
)#
#
# 3. Create the 'all_results_clean' data frame by filtering#
all_results_clean = all_results_linked %>%#
  filter(!is.na(standardized_y) & !is.na(Donor) & !is.na(Sex))#
if (nrow(all_results_clean) == 0) {#
  stop("No matching data found after joining + filtering. Check 'Fname' columns in your linker files.")#
}#
# Harmonize inferred_sex to match phenotype file sex values#
all_results_clean = all_results_clean %>%#
 mutate(inferred_sex = substr(inferred_sex, 1, 1))#
#------------------------------------------------#
# QC: Check Phenotype Sex vs. Inferred Sex#
#------------------------------------------------#
message("--- QC: Cross-checking Phenotype Sex vs. Inferred Sex ---")#
message("NOTE: This version of sesame only supports 'M'/'F' inference, not aneuploidy detection.")#
#
# Create the 2x2 Confusion Matrix#
sex_table <- table(#
  'Phenotype (File)' = all_results_clean$Sex, #
  'Inferred (sesame)' = all_results_clean$inferred_sex,#
  useNA = "ifany",#
  dnn = c("Phenotype (File)", "Inferred (sesame)")#
)#
#
print(sex_table)#
#
# Find and report all discordant samples#
discordant_samples <- all_results_clean %>%#
  dplyr::filter(Sex != inferred_sex & !is.na(inferred_sex)) %>%#
  dplyr::select(sample_name, Donor, 'Phenotype_Sex' = Sex, 'Inferred' = inferred_sex, dataset) %>%#
  dplyr::distinct()#
#
if (nrow(discordant_samples) > 0) {#
  message("\n!!! WARNING: Found ", nrow(discordant_samples), " discordant sex samples. Please investigate: !!!")#
  print(as.data.frame(discordant_samples))#
} else {#
  message("\n>>> Sex check passed. All inferred sexes match phenotype file.")#
}#
message("----------------------------------------------------------")#
# Convert *inferred* Sex to factor (for plotting)#
all_results_clean$inferred_sex = as.factor(all_results_clean$inferred_sex)#
#
# --- Create a sorting order based on DONOR mean intensity ---#
donor_order <- all_results_clean %>%#
  group_by(Donor) %>% #
  summarize(mean_y = mean(standardized_y, na.rm = TRUE)) %>%#
  arrange(mean_y) %>%#
  pull(Donor) #
#
# Apply this new order to the Donor column by converting it to a factor#
all_results_clean$Donor_sorted <- factor(#
  all_results_clean$Donor, #
  levels = donor_order#
)#
#
message("Data linked and sorted by Donor. Generating new plots...")#
#
#-----------------------------------------------------------------#
## 7. Create and Save New Visualizations (Revised)#
#-----------------------------------------------------------------#
#
pdf(output_pdf, width = 12, height = 16)#
#
# ---#
# PLOT 1: Sex Distribution (Page 1) - REVISED#
# ---#
#
g1 <- ggplot(all_results_clean, #
             aes(x = inferred_sex, y = standardized_y, fill = inferred_sex)) +#
  geom_boxplot(alpha = 0.4, outlier.shape = NA, width = 0.5) +#
  geom_jitter(aes(color = inferred_sex), width = 0.15, alpha = 0.6, size = 2) +#
  scale_color_brewer(palette = "Set2", name = "Inferred Sex") +#
  scale_fill_brewer(palette = "Set2", name = "Inferred Sex") +#
  labs(#
    title = "Plot 1: Y Intensity Distribution by Inferred Sex",#
    subtitle = "Mosaic LOY samples appear as 'M' (Male) points with intensity between 'F' and 'M' clusters.",#
    x = NULL, # 1. Remove x-axis title#
    y = "Standardized Y Intensity (Y / Autosomal)"#
  ) +#
  theme_minimal(base_size = 14) +#
  theme(#
    legend.position = "bottom",#
    panel.grid.major.x = element_blank(),#
    panel.grid.minor.y = element_blank(),#
    # 2. Increase label sizes#
    axis.title.y = element_text(size = 16),#
    axis.text.x = element_text(face = "bold", size = 14),#
    axis.text.y = element_text(size = 12)#
  )#
#
print(g1)#
# ---#
# PLOT 2: Data Missingness Pattern (Page 2) - NEW PLOT#
# ---#
# This plot uses the pre-filtered 'all_results_linked' to show data presence/absence.#
#
# 1. Create the 'has_data' column#
missingness_df <- all_results_linked %>%#
  mutate(has_data = !is.na(standardized_y))#
#
# 2. Create the tile plot#
g2 <- ggplot(missingness_df, #
             aes(x = Donor_sorted, #
                 y = dataset, #
                 fill = has_data)) +#
  geom_tile(color = "gray90", linewidth = 0.1) +#
  # Use a simple, clear color scale#
  scale_fill_manual(#
    name = "Data Status",#
    values = c("TRUE" = "#1a9641", "FALSE" = "#fde0ef"), # Green / Light Pink#
    labels = c("TRUE" = "Present", "FALSE" = "Missing/NA")#
  ) + #
  # Facet by Phenotype Sex#
  facet_grid(. ~ Sex, scales = "free_x", space = "free_x") + #
  labs(#
    title = "Plot 2: Data Missingness Pattern by Donor and Dataset",#
    subtitle = "Donors (x-axis) sorted by mean intensity. 'Missing' includes raw data NAs and failed QC.",#
    x = "Donor (Sorted Low to High)",#
    y = "Dataset"#
  ) +#
  theme_minimal(base_size = 12) +#
  theme(#
    axis.text.x = element_text(angle = 90, hjust = 1, vjust = 0.5, size = 4),#
    panel.grid.major = element_blank(),#
    strip.text.x = element_text(size = 14, face = "bold"), #
    legend.position = "bottom",#
    # Make axis titles larger#
    axis.title = element_text(size = 16)#
  )#
#
print(g2)#
# ---#
# PLOT 3: Dot Plot by Donor (Page 3) - REVISED#
# ---#
#
g3 <- ggplot(all_results_clean, #
             aes(x = standardized_y, #
                 y = Donor_sorted,#
                 color = dataset)) +#
  geom_point(alpha = 0.8, size = 2) +#
  # 1. Use high-contrast color palette#
  scale_color_brewer(name = "Dataset", palette = "Set1") + #
  facet_wrap(~ inferred_sex, scales = "free_y", ncol = 1) +#
  labs(#
    title = "Plot 3: Standardized Y Intensity by Donor",#
    subtitle = "Donors (y-axis) are sorted by their mean intensity. Facets show clear separation by inferred sex.",#
    x = "Standardized Y Intensity",#
    y = "Donor (Sorted Low to High)"#
  ) +#
  theme_minimal(base_size = 12) +#
  theme(#
    axis.text.y = element_text(size = 4), #
    panel.grid.major.y = element_blank(),#
    strip.text = element_text(size = 12, face = "bold"),#
    legend.position = "bottom",#
    # 2. Larger axis titles and labels#
    axis.title = element_text(size = 16),#
    axis.text.x = element_text(size = 12)#
  )#
#
print(g3)#
# ---#
# PLOT 4: 4x4 Grid for MALE Donors (Page 4) - REVISED#
# ---#
#
# Tell R to start a new page in the PDF#
grid.newpage()#
#
# 1. Filter for Males only#
males_only_df <- all_results_clean %>%#
  filter(inferred_sex == "M")#
#
# 2. Define the fixed Y-axis limit#
# NOTE: Set to [0, 0.6] as the M-cluster is ~0.5. #
# This captures LOY (0.0) up to normal males.#
y_limit <- c(0, 0.6)#
#
# 3. Get the list of male donors in the correct sorted order#
male_donor_levels <- levels(all_results_clean$Donor_sorted)[#
  levels(all_results_clean$Donor_sorted) %in% males_only_df$Donor#
]#
#
# 4. Get dataset names#
dataset_names <- unique(males_only_df$dataset)#
if (length(dataset_names) > 16) {#
  message(paste(#
    "Warning: Found", length(dataset_names), "datasets, but only plotting the first 16 on Page 4."#
  ))#
  dataset_names <- dataset_names[1:16]#
}#
#
# 5. Create list to hold plots#
plot_list <- list()#
#
# 6. Loop and create plots#
for (d_name in dataset_names) {#
  plot_data <- males_only_df %>% #
    filter(dataset == d_name)#
  g_sub <- ggplot(plot_data, aes(x = Donor_sorted, y = standardized_y)) +#
    geom_point(aes(color = standardized_y), alpha = 0.8) +#
    # Use the same high-contrast color scale as the heatmap#
    scale_color_gradient2(#
      low = "#0571b0", mid = "#f7f7f7", high = "#ca0020",#
      midpoint = 0.25, limits = y_limit, oob = scales::squish # squish outliers#
    ) +#
    # --- KEY CHANGES ---#
    # 1. Fix the Y-axis scale#
    coord_cartesian(ylim = y_limit) +#
    # 2. Ensure all plots use the full, ordered list of male donors on x-axis#
    scale_x_discrete(limits = male_donor_levels) +#
    labs(title = d_name, x = NULL, y = NULL) +#
    theme_minimal() +#
    theme(#
      # 3. Rotate donor IDs, size to fit#
      axis.text.x = element_text(angle = 90, vjust = 0.5, size = 3),#
      # 4. Larger y-axis labels#
      axis.text.y = element_text(size = 10), #
      legend.position = "none",#
      plot.title = element_text(size = 10, face = "bold", hjust = 0.5),#
      panel.grid.minor = element_blank(),#
      panel.grid.major.x = element_blank() # Remove vertical gridlines#
    )#
  plot_list[[d_name]] <- g_sub#
}#
#
# 7. Arrange the grid with large, shared axis titles#
grid.arrange(#
  grobs = plot_list, #
  ncol = 4,#
  top = textGrob("Plot 4: Male Donor Y-Intensity by Dataset (Fixed Y-Axis)", #
                 gp = gpar(fontsize = 18, fontface = "bold")),#
  left = textGrob("Standardized Y Intensity", rot = 90, #
                 gp = gpar(fontsize = 16)),#
  bottom = textGrob("Donor (Sorted Low to High)", #
                 gp = gpar(fontsize = 16))#
)#
# ---#
# Close the PDF file#
# ---#
dev.off()#
#
message(paste("\nAll processing complete. 4 plot pages saved to:", output_pdf))
rm(list=ls()); gc();
#-----------------------------------------------------------------#
## 1. Setup: Load Libraries  #
#-----------------------------------------------------------------#
library(sesame)#
library(GenomicRanges)#
library(tidyverse)#
library(readr)#
library(stringr)#
library(readxl)#
library(RColorBrewer) #
library(progressr)    #
library(progress)     #
library(gridExtra)    #
library(grid)#
#
# --- Configure progress bars ---#
handlers(global = TRUE) #
handlers("progress")#
#-----------------------------------------------------------------#
## 2. Define Your Input/Output Paths (Updated)#
#-----------------------------------------------------------------#
# !!! IMPORTANT: Update this path to your directory#
sdf_directory <- "/Users/bc/Documents/gestalt/analysis/sdfs/" #
#
# Define the name for the final combined PDF#
output_pdf <- "/Users/bc/Desktop/GESTALT-Y-intensities.pdf"#
#
# !!! IMPORTANT: Update this path to your LINKER file directory#
linker_directory <- "/Users/bc/Documents/gestalt/"#
#
# Load Phenotype file#
pheno = readxl::read_excel("/Users/bc/Documents/gestalt/pheno/Gestalt Demographics.xlsx",1, skip=1)#
pheno = as.data.frame(pheno)#
names(pheno) = c("Donor", "DATE", "Age", "Sex", "BMI")#
#-----------------------------------------------------------------#
## 3. Load and Assemble Linker Key  #
#-----------------------------------------------------------------#
#
message("Finding and assembling linker files...")#
#
# Find all files matching the "samples.*.txt" pattern#
linker_file_paths <- list.files(#
  path = linker_directory,#
  pattern = "^samples\\..*\\.txt$", # Regex: starts with "samples." and ends with ".txt"#
  full.names = TRUE,#
  recursive = TRUE#
)#
#
if (length(linker_file_paths) == 0) {#
  stop(paste("No linker files matching 'samples.*.txt' found in:", linker_directory))#
} else {#
  message(paste("Found", length(linker_file_paths), "linker files. Reading and combining..."))#
}#
#
# Read and combine linker files#
# "c" = character#
# .default = "_" tells read_tsv to "skip all other columns"#
#
linker_df <- purrr::map_dfr(linker_file_paths, ~ readr::read_tsv(#
  .x, #
  col_types = cols(#
    Fname = "c", #
    Donor = "c", #
    .default = "_"  # unnecessary columns (inconsistencies lead to errors)#
  ), #
  show_col_types = FALSE#
))#
linker_df <- linker_df %>%#
  dplyr::distinct(Fname, .keep_all = TRUE) %>%    # Keep unique Fname mappings#
  mutate( Donor = tolower(str_remove_all(Donor, "-")) ) %>%   # Remove hyphens and convert to lowercase#
  select(Fname, Donor)  # Keep only desired columns#
#
message(paste("Linker key assembled with", nrow(linker_df), "unique Samplename-to-Donor mappings."))#
# Tidy phenotype file (containing sex data)#
sex_df = pheno %>%#
		dplyr::select(Donor, Sex) %>%#
		dplyr::filter(Sex %in% c("M", "F")) %>%#
		mutate( Donor = tolower(str_remove_all(Donor, "-")) ) %>%   # Remove hyphens and convert to lowercase#
		dplyr::distinct(Donor, .keep_all = TRUE) #
#-----------------------------------------------------------------#
## 4. Manifest & Region Prep (Restored to Original)#
#-----------------------------------------------------------------#
#
# Download array manifest#
url <- "https://github.com/zhou-lab/InfiniumAnnotationV1/raw/main/Anno/EPIC/EPIC.hg19.manifest.tsv.gz"#
manifest <- readr::read_tsv(url, show_col_types = FALSE)#
#
manifest <- manifest[!is.na(manifest$CpG_beg) & !is.na(manifest$CpG_end),]#
manifest <- manifest %>%#
  dplyr::filter(grepl("^chr[0-9XY]+$", CpG_chrm))#
manifest_gr <- GRanges(#
  seqnames = manifest$CpG_chrm,#
  ranges = IRanges(start = manifest$CpG_beg, end = manifest$CpG_end),#
  probeID = manifest$Probe_ID#
)#
#
# Define genomic regions #
y_region_gr <- GRanges(#
  seqnames = "chrY",#
  ranges = IRanges(start = 2694521, end = 59034049)#
)#
overlaps_y <- findOverlaps(manifest_gr, y_region_gr)#
y_region_probes <- manifest_gr[queryHits(overlaps_y)]$probeID#
#
autosomal_chroms <- paste0("chr", 1:22)#
autosomal_probes <- manifest_gr[seqnames(manifest_gr) %in% autosomal_chroms]$probeID#
#
message("Manifest and probe regions defined manually.")#
#-----------------------------------------------------------------#
## 5. Iterative Processing (SDFs) -- STABLE VERSION#
#-----------------------------------------------------------------#
#
message("Starting iterative processing of SDF files...")#
#
file_paths <- list.files(#
  path = sdf_directory,#
  pattern = "^sdfs_.*\\.RDS$",#
  full.names = TRUE#
)#
#
# --- DEBUG ---#
if (length(file_paths) > 2) {#
  message("--- DEBUG: Limiting analysis to 2 RDS files. ---")#
  file_paths <- file_paths[1:2]	#
}#
# ---#
#
# Check that probe lists from Section 4 exist#
if (!exists("autosomal_probes") || !exists("y_region_probes")) {#
  stop("Error: 'autosomal_probes' or 'y_region_probes' not found. Please re-run Section 4.")#
}#
all_results_list <- list()#
#
for (file_path in file_paths) {#
  filename <- basename(file_path)#
  dataset_name <- gsub("^sdfs_|.RDS$", "", filename)#
  message(paste("Processing dataset:", dataset_name, "..."))#
  sdf.list <- readRDS(file_path)#
  # --- FIX: Removed the with_progress() wrapper ---#
  results_df <- purrr::map_dfr(sdf.list, ~{#
    # Removed the p() call#
    sdf <- .x#
    # Get Karyotype  #
    sset <- tryCatch(#
      sesame::openSesame(sdf),#
      error = function(e) { return(NULL) }#
    )#
    inferred_sex = if (is.null(sset)) NA_character_ else sesame::inferSex(sset)#
    # Compute intensities#
    total_intensity <- totalIntensities(sdf)#
    if (length(total_intensity) == 0) {#
      return(data.frame(#
        median_y = NA_real_,#
        median_auto = NA_real_,#
        standardized_y = NA_real_,#
        inferred_sex = inferred_sex#
      ))#
    }#
    y_intensities <- total_intensity[names(total_intensity) %in% y_region_probes]#
    median_y_intensity <- median(y_intensities, na.rm = TRUE)#
    auto_intensities <- total_intensity[names(total_intensity) %in% autosomal_probes]#
    median_auto_intensity <- median(auto_intensities, na.rm = TRUE)#
    standardized_y <- median_y_intensity / median_auto_intensity#
    data.frame(#
      median_y = median_y_intensity,#
      median_auto = median_auto_intensity,#
      standardized_y = standardized_y,#
      inferred_sex = inferred_sex#
    )#
  }, .id = "sample_name") # This .id is the 'Fname'#
  # --- END FIX ---#
  # Add the dataset name#
  results_df$dataset <- dataset_name#
  all_results_list[[dataset_name]] <- results_df#
}#
#
message("All SDF files processed. Combining results...")#
#-----------------------------------------------------------------#
## 6. Combine, Link, and Prepare for Plotting  #
#-----------------------------------------------------------------#
#
# Combine all results from the list into one big data frame#
all_results_df <- dplyr::bind_rows(all_results_list)#
#
# Join the intensity results with the linker file#
all_results_linked <- all_results_df %>%#
  dplyr::left_join(linker_df, by = c("sample_name" = "Fname"))#
# Join with Sex data (from your pheno file)#
all_results_linked = all_results_linked %>%#
  dplyr::left_join(sex_df, by = c("Donor" = "Donor"))#
# 1. Sort order by Donor mean intensity (for Plot 2)#
donor_order <- all_results_linked %>%#
  group_by(Donor) %>% #
  summarize(mean_y = mean(standardized_y, na.rm = TRUE)) %>%#
  # Donors with all NA will have mean_y = NaN. This sorts them to one end.#
  arrange(mean_y) %>%#
  pull(Donor) #
#
# 2. Apply this new order to the Donor column by converting it to a factor#
# This factor is applied to the *pre-filtered* data#
all_results_linked$Donor_sorted <- factor(#
  all_results_linked$Donor, #
  levels = donor_order#
)#
#
# 3. Create the 'all_results_clean' data frame by filtering#
all_results_clean = all_results_linked %>%#
  filter(!is.na(standardized_y) & !is.na(Donor) & !is.na(Sex))#
if (nrow(all_results_clean) == 0) {#
  stop("No matching data found after joining + filtering. Check 'Fname' columns in your linker files.")#
}#
# Harmonize inferred_sex to match phenotype file sex values#
all_results_clean = all_results_clean %>%#
 mutate(inferred_sex = substr(inferred_sex, 1, 1))#
#------------------------------------------------#
# QC: Check Phenotype Sex vs. Inferred Sex#
#------------------------------------------------#
message("--- QC: Cross-checking Phenotype Sex vs. Inferred Sex ---")#
message("NOTE: This version of sesame only supports 'M'/'F' inference, not aneuploidy detection.")#
#
# Create the 2x2 Confusion Matrix#
sex_table <- table(#
  'Phenotype (File)' = all_results_clean$Sex, #
  'Inferred (sesame)' = all_results_clean$inferred_sex,#
  useNA = "ifany",#
  dnn = c("Phenotype (File)", "Inferred (sesame)")#
)#
#
print(sex_table)#
#
# Find and report all discordant samples#
discordant_samples <- all_results_clean %>%#
  dplyr::filter(Sex != inferred_sex & !is.na(inferred_sex)) %>%#
  dplyr::select(sample_name, Donor, 'Phenotype_Sex' = Sex, 'Inferred' = inferred_sex, dataset) %>%#
  dplyr::distinct()#
#
if (nrow(discordant_samples) > 0) {#
  message("\n!!! WARNING: Found ", nrow(discordant_samples), " discordant sex samples. Please investigate: !!!")#
  print(as.data.frame(discordant_samples))#
} else {#
  message("\n>>> Sex check passed. All inferred sexes match phenotype file.")#
}#
message("----------------------------------------------------------")#
# Convert *inferred* Sex to factor (for plotting)#
all_results_clean$inferred_sex = as.factor(all_results_clean$inferred_sex)#
#
# --- Create a sorting order based on DONOR mean intensity ---#
donor_order <- all_results_clean %>%#
  group_by(Donor) %>% #
  summarize(mean_y = mean(standardized_y, na.rm = TRUE)) %>%#
  arrange(mean_y) %>%#
  pull(Donor) #
#
# Apply this new order to the Donor column by converting it to a factor#
all_results_clean$Donor_sorted <- factor(#
  all_results_clean$Donor, #
  levels = donor_order#
)#
#
message("Data linked and sorted by Donor. Generating new plots...")#
#-----------------------------------------------------------------#
## 7. Create and Save New Visualizations (Revised)#
#-----------------------------------------------------------------#
#
pdf(output_pdf, width = 12, height = 16)#
#
# ---#
# PLOT 1: Sex Distribution (Page 1) - REVISED#
# ---#
#
g1 <- ggplot(all_results_clean, #
             aes(x = inferred_sex, y = standardized_y, fill = inferred_sex)) +#
  geom_boxplot(alpha = 0.4, outlier.shape = NA, width = 0.5) +#
  geom_jitter(aes(color = inferred_sex), width = 0.15, alpha = 0.6, size = 2) +#
  scale_color_brewer(palette = "Set2", name = "Inferred Sex") +#
  scale_fill_brewer(palette = "Set2", name = "Inferred Sex") +#
  labs(#
    title = "Plot 1: Y Intensity Distribution by Inferred Sex",#
    subtitle = "Mosaic LOY samples appear as 'M' (Male) points with intensity between 'F' and 'M' clusters.",#
    x = NULL, #
    y = "Standardized Y Intensity (Y / Autosomal)"#
  ) +#
  theme_minimal(base_size = 14) +#
  theme(#
    legend.position = "bottom",#
    panel.grid.major.x = element_blank(),#
    panel.grid.minor.y = element_blank(),#
    # --- KEY CHANGES: Doubled Sizes ---#
    axis.title.y = element_text(size = 32),#
    axis.text.x = element_text(face = "bold", size = 28),#
    axis.text.y = element_text(size = 24),#
    legend.title = element_text(size = 24),#
    legend.text = element_text(size = 22)#
    # --- END CHANGES ---#
  )#
#
# --- KEY CHANGE: Use grid.arrange to make the plot smaller on the page ---#
# This prints the plot into a 1x1 grid, with "heights" set to 80%#
# This makes the plot 80% of the page height.#
grid.arrange(g1, ncol = 1, heights = unit(0.8, "npc"))#
# ---#
# PLOT 2: Data Missingness Pattern (Page 2)#
# ---#
# This plot is unchanged and remains on Page 2.#
#
# 1. Create the 'has_data' column#
missingness_df <- all_results_linked %>%#
  mutate(has_data = !is.na(standardized_y))#
#
# 2. Create the tile plot#
g2 <- ggplot(missingness_df, #
             aes(x = Donor_sorted, #
                 y = dataset, #
                 fill = has_data)) +#
  geom_tile(color = "gray90", linewidth = 0.1) +#
  scale_fill_manual(#
    name = "Data Status",#
    values = c("TRUE" = "#1a9641", "FALSE" = "#fde0ef"), # Green / Light Pink#
    labels = c("TRUE" = "Present", "FALSE" = "Missing/NA")#
  ) + #
  facet_grid(. ~ Sex, scales = "free_x", space = "free_x") + #
  labs(#
    title = "Plot 2: Data Missingness Pattern by Donor and Dataset",#
    subtitle = "Donors (x-axis) sorted by mean intensity. 'Missing' includes raw data NAs and failed QC.",#
    x = "Donor (Sorted Low to High)",#
    y = "Dataset"#
  ) +#
  theme_minimal(base_size = 12) +#
  theme(#
    axis.text.x = element_text(angle = 90, hjust = 1, vjust = 0.5, size = 4),#
    panel.grid.major = element_blank(),#
    strip.text.x = element_text(size = 14, face = "bold"), #
    legend.position = "bottom",#
    axis.title = element_text(size = 16)#
  )#
#
print(g2)#
# ---#
# PLOT 3: Dot Plot by Donor (Page 3) - REVISED#
# ---#
#
g3 <- ggplot(all_results_clean, #
             aes(x = standardized_y, #
                 y = Donor_sorted,#
                 color = dataset)) +#
  geom_point(alpha = 0.8, size = 2) +#
  scale_color_brewer(name = "Dataset", palette = "Set1") + #
  facet_wrap(~ inferred_sex, scales = "free_y", ncol = 1) +#
  labs(#
    title = "Plot 3: Standardized Y Intensity by Donor",#
    subtitle = "Donors (y-axis) are sorted by their mean intensity. Facets show clear separation by inferred sex.",#
    x = "Standardized Y Intensity",#
    y = "Donor (Sorted Low to High)"#
  ) +#
  theme_minimal(base_size = 12) +#
  theme(#
    axis.text.y = element_text(size = 4), #
    panel.grid.major.y = element_blank(),#
    strip.text = element_text(size = 12, face = "bold"),#
    # --- KEY CHANGES: Doubled Sizes ---#
    axis.title = element_text(size = 32),#
    axis.text.x = element_text(size = 24),#
    legend.position = "bottom",#
    legend.title = element_text(size = 24),#
    legend.text = element_text(size = 22)#
    # --- END CHANGES ---#
  )#
#
# --- KEY CHANGE: Use grid.arrange to make the plot narrower ---#
# This prints the plot into a 1x1 grid, with "widths" set to 90%#
grid.arrange(g3, ncol = 1, widths = unit(0.9, "npc"))#
# ---#
# PLOT 4: 4x4 Grid for MALE Donors (Page 4)#
# ---#
# This plot logic is unchanged. "Quadrants of smaller scatterplots"#
# is what grid.arrange(ncol=4) accomplishes.#
#
grid.newpage()#
#
males_only_df <- all_results_clean %>%#
  filter(inferred_sex == "M")#
#
y_limit <- c(0, 0.6)#
#
male_donor_levels <- levels(all_results_clean$Donor_sorted)[#
  levels(all_results_clean$Donor_sorted) %in% males_only_df$Donor#
]#
#
dataset_names <- unique(males_only_df$dataset)#
if (length(dataset_names) > 16) {#
  message(paste(#
    "Warning: Found", length(dataset_names), "datasets, but only plotting the first 16 on Page 4."#
  ))#
  dataset_names <- dataset_names[1:16]#
}#
#
plot_list <- list()#
#
for (d_name in dataset_names) {#
  plot_data <- males_only_df %>% #
    filter(dataset == d_name)#
  g_sub <- ggplot(plot_data, aes(x = Donor_sorted, y = standardized_y)) +#
    geom_point(aes(color = standardized_y), alpha = 0.8) +#
    scale_color_gradient2(#
      low = "#0571b0", mid = "#f7f7f7", high = "#ca0020",#
      midpoint = 0.25, limits = y_limit, oob = scales::squish #
    ) +#
    coord_cartesian(ylim = y_limit) +#
    scale_x_discrete(limits = male_donor_levels) +#
    labs(title = d_name, x = NULL, y = NULL) +#
    theme_minimal() +#
    theme(#
      axis.text.x = element_text(angle = 90, vjust = 0.5, size = 3),#
      axis.text.y = element_text(size = 10), #
      legend.position = "none",#
      plot.title = element_text(size = 10, face = "bold", hjust = 0.5),#
      panel.grid.minor = element_blank(),#
      panel.grid.major.x = element_blank() #
    )#
  plot_list[[d_name]] <- g_sub#
}#
#
# This arranges the plots into a 4-column grid (a "4x4 grid" if 16 plots)#
grid.arrange(#
  grobs = plot_list, #
  ncol = 4, #
  top = textGrob("Plot 4: Male Donor Y-Intensity by Dataset (Fixed Y-Axis)", #
                 gp = gpar(fontsize = 18, fontface = "bold")),#
  left = textGrob("Standardized Y Intensity", rot = 90, #
                 gp = gpar(fontsize = 16)),#
  bottom = textGrob("Donor (Sorted Low to High)", #
                 gp = gpar(fontsize = 16))#
)#
# ---#
# Close the PDF file#
# ---#
dev.off()#
#
message(paste("\nAll processing complete. 4 plot pages saved to:", output_pdf))
#-----------------------------------------------------------------#
## 1. Setup: Load Libraries  #
#-----------------------------------------------------------------#
library(sesame)#
library(GenomicRanges)#
library(tidyverse)#
library(readr)#
library(stringr)#
library(readxl)#
library(RColorBrewer) #
library(progressr)    #
library(progress)     #
library(gridExtra)    #
library(grid)#
#
# --- Configure progress bars ---#
handlers(global = TRUE) #
handlers("progress")#
#-----------------------------------------------------------------#
## 2. Define Your Input/Output Paths (Updated)#
#-----------------------------------------------------------------#
# !!! IMPORTANT: Update this path to your directory#
sdf_directory <- "/Users/bc/Documents/gestalt/analysis/sdfs/" #
#
# Define the name for the final combined PDF#
output_pdf <- "/Users/bc/Desktop/GESTALT-Y-intensities.pdf"#
#
# !!! IMPORTANT: Update this path to your LINKER file directory#
linker_directory <- "/Users/bc/Documents/gestalt/"#
#
# Load Phenotype file#
pheno = readxl::read_excel("/Users/bc/Documents/gestalt/pheno/Gestalt Demographics.xlsx",1, skip=1)#
pheno = as.data.frame(pheno)#
names(pheno) = c("Donor", "DATE", "Age", "Sex", "BMI")#
#-----------------------------------------------------------------#
## 3. Load and Assemble Linker Key  #
#-----------------------------------------------------------------#
#
message("Finding and assembling linker files...")#
#
# Find all files matching the "samples.*.txt" pattern#
linker_file_paths <- list.files(#
  path = linker_directory,#
  pattern = "^samples\\..*\\.txt$", # Regex: starts with "samples." and ends with ".txt"#
  full.names = TRUE,#
  recursive = TRUE#
)#
#
if (length(linker_file_paths) == 0) {#
  stop(paste("No linker files matching 'samples.*.txt' found in:", linker_directory))#
} else {#
  message(paste("Found", length(linker_file_paths), "linker files. Reading and combining..."))#
}#
#
# Read and combine linker files#
# "c" = character#
# .default = "_" tells read_tsv to "skip all other columns"#
#
linker_df <- purrr::map_dfr(linker_file_paths, ~ readr::read_tsv(#
  .x, #
  col_types = cols(#
    Fname = "c", #
    Donor = "c", #
    .default = "_"  # unnecessary columns (inconsistencies lead to errors)#
  ), #
  show_col_types = FALSE#
))#
linker_df <- linker_df %>%#
  dplyr::distinct(Fname, .keep_all = TRUE) %>%    # Keep unique Fname mappings#
  mutate( Donor = tolower(str_remove_all(Donor, "-")) ) %>%   # Remove hyphens and convert to lowercase#
  select(Fname, Donor)  # Keep only desired columns#
#
message(paste("Linker key assembled with", nrow(linker_df), "unique Samplename-to-Donor mappings."))#
# Tidy phenotype file (containing sex data)#
sex_df = pheno %>%#
		dplyr::select(Donor, Sex) %>%#
		dplyr::filter(Sex %in% c("M", "F")) %>%#
		mutate( Donor = tolower(str_remove_all(Donor, "-")) ) %>%   # Remove hyphens and convert to lowercase#
		dplyr::distinct(Donor, .keep_all = TRUE) #
#-----------------------------------------------------------------#
## 4. Manifest & Region Prep (Restored to Original)#
#-----------------------------------------------------------------#
#
# Download array manifest#
url <- "https://github.com/zhou-lab/InfiniumAnnotationV1/raw/main/Anno/EPIC/EPIC.hg19.manifest.tsv.gz"#
manifest <- readr::read_tsv(url, show_col_types = FALSE)#
#
manifest <- manifest[!is.na(manifest$CpG_beg) & !is.na(manifest$CpG_end),]#
manifest <- manifest %>%#
  dplyr::filter(grepl("^chr[0-9XY]+$", CpG_chrm))#
manifest_gr <- GRanges(#
  seqnames = manifest$CpG_chrm,#
  ranges = IRanges(start = manifest$CpG_beg, end = manifest$CpG_end),#
  probeID = manifest$Probe_ID#
)#
#
# Define genomic regions #
y_region_gr <- GRanges(#
  seqnames = "chrY",#
  ranges = IRanges(start = 2694521, end = 59034049)#
)#
overlaps_y <- findOverlaps(manifest_gr, y_region_gr)#
y_region_probes <- manifest_gr[queryHits(overlaps_y)]$probeID#
#
autosomal_chroms <- paste0("chr", 1:22)#
autosomal_probes <- manifest_gr[seqnames(manifest_gr) %in% autosomal_chroms]$probeID#
#
message("Manifest and probe regions defined manually.")#
#-----------------------------------------------------------------#
## 5. Iterative Processing (SDFs) -- STABLE VERSION#
#-----------------------------------------------------------------#
#
message("Starting iterative processing of SDF files...")#
#
file_paths <- list.files(#
  path = sdf_directory,#
  pattern = "^sdfs_.*\\.RDS$",#
  full.names = TRUE#
)#
#
# --- DEBUG ---#
if (length(file_paths) > 2) {#
  message("--- DEBUG: Limiting analysis to 2 RDS files. ---")#
  file_paths <- file_paths[1:2]	#
}#
# ---#
#
# Check that probe lists from Section 4 exist#
if (!exists("autosomal_probes") || !exists("y_region_probes")) {#
  stop("Error: 'autosomal_probes' or 'y_region_probes' not found. Please re-run Section 4.")#
}#
all_results_list <- list()#
#
for (file_path in file_paths) {#
  filename <- basename(file_path)#
  dataset_name <- gsub("^sdfs_|.RDS$", "", filename)#
  message(paste("Processing dataset:", dataset_name, "..."))#
  sdf.list <- readRDS(file_path)#
  # --- FIX: Removed the with_progress() wrapper ---#
  results_df <- purrr::map_dfr(sdf.list, ~{#
    # Removed the p() call#
    sdf <- .x#
    # Get Karyotype  #
    sset <- tryCatch(#
      sesame::openSesame(sdf),#
      error = function(e) { return(NULL) }#
    )#
    inferred_sex = if (is.null(sset)) NA_character_ else sesame::inferSex(sset)#
    # Compute intensities#
    total_intensity <- totalIntensities(sdf)#
    if (length(total_intensity) == 0) {#
      return(data.frame(#
        median_y = NA_real_,#
        median_auto = NA_real_,#
        standardized_y = NA_real_,#
        inferred_sex = inferred_sex#
      ))#
    }#
    y_intensities <- total_intensity[names(total_intensity) %in% y_region_probes]#
    median_y_intensity <- median(y_intensities, na.rm = TRUE)#
    auto_intensities <- total_intensity[names(total_intensity) %in% autosomal_probes]#
    median_auto_intensity <- median(auto_intensities, na.rm = TRUE)#
    standardized_y <- median_y_intensity / median_auto_intensity#
    data.frame(#
      median_y = median_y_intensity,#
      median_auto = median_auto_intensity,#
      standardized_y = standardized_y,#
      inferred_sex = inferred_sex#
    )#
  }, .id = "sample_name") # This .id is the 'Fname'#
  # --- END FIX ---#
  # Add the dataset name#
  results_df$dataset <- dataset_name#
  all_results_list[[dataset_name]] <- results_df#
}#
#
message("All SDF files processed. Combining results...")#
#-----------------------------------------------------------------#
## 6. Combine, Link, and Prepare for Plotting  #
#-----------------------------------------------------------------#
#
# Combine all results from the list into one big data frame#
all_results_df <- dplyr::bind_rows(all_results_list)#
#
# Join the intensity results with the linker file#
all_results_linked <- all_results_df %>%#
  dplyr::left_join(linker_df, by = c("sample_name" = "Fname"))#
# Join with Sex data (from your pheno file)#
all_results_linked = all_results_linked %>%#
  dplyr::left_join(sex_df, by = c("Donor" = "Donor"))#
# 1. Sort order by Donor mean intensity (for Plot 2)#
donor_order <- all_results_linked %>%#
  group_by(Donor) %>% #
  summarize(mean_y = mean(standardized_y, na.rm = TRUE)) %>%#
  # Donors with all NA will have mean_y = NaN. This sorts them to one end.#
  arrange(mean_y) %>%#
  pull(Donor) #
#
# 2. Apply this new order to the Donor column by converting it to a factor#
# This factor is applied to the *pre-filtered* data#
all_results_linked$Donor_sorted <- factor(#
  all_results_linked$Donor, #
  levels = donor_order#
)#
#
# 3. Create the 'all_results_clean' data frame by filtering#
all_results_clean = all_results_linked %>%#
  filter(!is.na(standardized_y) & !is.na(Donor) & !is.na(Sex))#
if (nrow(all_results_clean) == 0) {#
  stop("No matching data found after joining + filtering. Check 'Fname' columns in your linker files.")#
}#
# Harmonize inferred_sex to match phenotype file sex values#
all_results_clean = all_results_clean %>%#
 mutate(inferred_sex = substr(inferred_sex, 1, 1))#
#------------------------------------------------#
# QC: Check Phenotype Sex vs. Inferred Sex#
#------------------------------------------------#
message("--- QC: Cross-checking Phenotype Sex vs. Inferred Sex ---")#
message("NOTE: This version of sesame only supports 'M'/'F' inference, not aneuploidy detection.")#
#
# Create the 2x2 Confusion Matrix#
sex_table <- table(#
  'Phenotype (File)' = all_results_clean$Sex, #
  'Inferred (sesame)' = all_results_clean$inferred_sex,#
  useNA = "ifany",#
  dnn = c("Phenotype (File)", "Inferred (sesame)")#
)#
#
print(sex_table)#
#
# Find and report all discordant samples#
discordant_samples <- all_results_clean %>%#
  dplyr::filter(Sex != inferred_sex & !is.na(inferred_sex)) %>%#
  dplyr::select(sample_name, Donor, 'Phenotype_Sex' = Sex, 'Inferred' = inferred_sex, dataset) %>%#
  dplyr::distinct()#
#
if (nrow(discordant_samples) > 0) {#
  message("\n!!! WARNING: Found ", nrow(discordant_samples), " discordant sex samples. Please investigate: !!!")#
  print(as.data.frame(discordant_samples))#
} else {#
  message("\n>>> Sex check passed. All inferred sexes match phenotype file.")#
}#
message("----------------------------------------------------------")#
# Convert *inferred* Sex to factor (for plotting)#
all_results_clean$inferred_sex = as.factor(all_results_clean$inferred_sex)#
#
# --- Create a sorting order based on DONOR mean intensity ---#
donor_order <- all_results_clean %>%#
  group_by(Donor) %>% #
  summarize(mean_y = mean(standardized_y, na.rm = TRUE)) %>%#
  arrange(mean_y) %>%#
  pull(Donor) #
#
# Apply this new order to the Donor column by converting it to a factor#
all_results_clean$Donor_sorted <- factor(#
  all_results_clean$Donor, #
  levels = donor_order#
)#
#
message("Data linked and sorted by Donor. Generating new plots...")#
#-----------------------------------------------------------------#
## 7. Create and Save New Visualizations (Revised)#
#-----------------------------------------------------------------#
#
pdf(output_pdf, width = 12, height = 16)#
#
# ---#
# PLOT 1: Sex Distribution (Page 1) - REVISED#
# ---#
#
g1 <- ggplot(all_results_clean, #
             aes(x = inferred_sex, y = standardized_y, fill = inferred_sex)) +#
  geom_boxplot(alpha = 0.4, outlier.shape = NA, width = 0.5) +#
  geom_jitter(aes(color = inferred_sex), width = 0.15, alpha = 0.6, size = 2) +#
  scale_color_brewer(palette = "Set2") +#
  scale_fill_brewer(palette = "Set2") +#
  labs(#
    # 3. Triple title/subtitle size#
    title = "Plot 1: Y Intensity Distribution",#
    subtitle = "Mosaic LOY = 'M' points between 'F' and 'M' clusters.",#
    # 4. Add back x-axis title#
    x = "Inferred Sex", #
    y = "Standardized Y Intensity (Y / Autosomal)"#
  ) +#
  theme_minimal(base_size = 14) +#
  theme(#
    # 4. Remove legend#
    legend.position = "none",#
    panel.grid.major.x = element_blank(),#
    panel.grid.minor.y = element_blank(),#
    # 3. Triple title/subtitle size#
    plot.title = element_text(size = 42, face = "bold"),#
    plot.subtitle = element_text(size = 36),#
    # 2. Wider spacing (from larger text sizes)#
    axis.title.y = element_text(size = 32),#
    axis.title.x = element_text(size = 32), # 4.#
    axis.text.x = element_text(face = "bold", size = 28),#
    axis.text.y = element_text(size = 24),#
    # 2. Add plot margin for spacing#
    plot.margin = unit(c(1, 1, 1, 1), "cm")#
  )#
#
# 1. Make plot 0.33 of the page width#
grid.arrange(g1, ncol = 1, widths = unit(0.33, "npc"))#
# ---#
# PLOT 2: Data Missingness Pattern (Page 2) - REVISED#
# ---#
missingness_df <- all_results_linked %>%#
  mutate(has_data = !is.na(standardized_y))#
#
g2 <- ggplot(missingness_df, #
             aes(x = Donor_sorted, #
                 y = dataset, #
                 fill = has_data)) +#
  geom_tile(color = "gray90", linewidth = 0.1) +#
  scale_fill_manual(#
    values = c("TRUE" = "#1a9641", "FALSE" = "#fde0ef"), # Green / Light Pink#
    labels = c("TRUE" = "Present", "FALSE" = "Missing/NA")#
  ) + #
  # drop=FALSE ensures M/F facets appear even if empty#
  facet_grid(. ~ Sex, scales = "free_x", space = "free_x", drop = FALSE) + #
  labs(#
    # 4. Triple title size#
    title = "Plot 2: Data Missingness Pattern",#
    subtitle = "Donors (x-axis) sorted by mean intensity. 'Missing' includes raw data NAs and failed QC.",#
    x = "Donor (Sorted Low to High)",#
    # 2. Y-axis title#
    y = "Cell type"#
  ) +#
  theme_minimal(base_size = 12) +#
  theme(#
    # 1. Double axis label sizes#
    axis.text.x = element_text(angle = 90, hjust = 1, vjust = 0.5, size = 8),#
    axis.text.y = element_text(size = 16),#
    panel.grid.major = element_blank(),#
    strip.text.x = element_text(size = 28, face = "bold"), #
    # 3. Remove legend#
    legend.position = "none",#
    # 1. Double axis title sizes#
    axis.title = element_text(size = 32),#
    # 4. Triple title size#
    plot.title = element_text(size = 36, face = "bold")#
  )#
#
print(g2)#
# ---#
# PLOT 3: Dot Plot by Donor (Page 3) - REVISED#
# ---#
g3 <- ggplot(all_results_clean, #
             aes(x = standardized_y, #
                 y = Donor_sorted,#
                 color = dataset)) +#
  geom_point(alpha = 0.8, size = 2) +#
  scale_color_brewer(name = "Dataset", palette = "Set1") + #
  facet_wrap(~ inferred_sex, scales = "free_y", ncol = 1) +#
  labs(#
    # 1. Triple title/subtitle size#
    title = "Plot 3: Standardized Y Intensity by Donor",#
    subtitle = "Donors (y-axis) are sorted by their mean intensity.",#
    x = "Standardized Y Intensity",#
    y = "Donor (Sorted Low to High)"#
  ) +#
  theme_minimal(base_size = 12) +#
  theme(#
    axis.text.y = element_text(size = 4), #
    panel.grid.major.y = element_blank(),#
    # 2. Double grid titles#
    strip.text = element_text(size = 24, face = "bold"),#
    legend.position = "bottom",#
    # 1. Triple title/subtitle size#
    plot.title = element_text(size = 36, face = "bold"),#
    plot.subtitle = element_text(size = 30),#
    axis.title = element_text(size = 32),#
    axis.text.x = element_text(size = 24),#
    legend.title = element_text(size = 24),#
    legend.text = element_text(size = 22)#
  )#
#
# 3. Reduce plot size by 20% (80% width)#
grid.arrange(g3, ncol = 1, widths = unit(0.8, "npc"))#
# ---#
# PLOT 4: 4x4 Grid for MALE Donors (Page 4) - REVISED#
# ---#
grid.newpage()#
#
males_only_df <- all_results_clean %>%#
  filter(inferred_sex == "M")#
#
# 1. Set fixed Y-axis range to [0, 1.0]#
# This is a safer range than 0.5-1.0 and will show the data.#
y_limit <- c(0, 1.0) #
#
male_donor_levels <- levels(all_results_clean$Donor_sorted)[#
  levels(all_results_clean$Donor_sorted) %in% males_only_df$Donor#
]#
#
dataset_names <- unique(males_only_df$dataset)#
if (length(dataset_names) > 16) {#
  message(paste(#
    "Warning: Found", length(dataset_names), "datasets, but only plotting the first 16 on Page 4."#
  ))#
  dataset_names <- dataset_names[1:16]#
}#
#
plot_list <- list()#
#
for (d_name in dataset_names) {#
  plot_data <- males_only_df %>% #
    filter(dataset == d_name)#
  g_sub <- ggplot(plot_data, aes(x = Donor_sorted, y = standardized_y)) +#
    geom_point(aes(color = standardized_y), alpha = 0.8) +#
    scale_color_gradient2(#
      low = "#0571b0", mid = "#f7f7f7", high = "#ca0020",#
      midpoint = 0.25, limits = y_limit, oob = scales::squish #
    ) +#
    # 1. Set fixed Y-axis range#
    coord_cartesian(ylim = y_limit) +#
    scale_x_discrete(limits = male_donor_levels) +#
    labs(title = d_name, x = NULL, y = NULL) +#
    theme_minimal() +#
    theme(#
      axis.text.x = element_text(angle = 90, vjust = 0.5, size = 3),#
      axis.text.y = element_text(size = 10), _#
      legend.position = "none",#
      plot.title = element_text(size = 10, face = "bold", hjust = 0.5),#
      panel.grid.minor = element_blank(),#
      panel.grid.major.x = element_blank() #
    )#
  plot_list[[d_name]] <- g_sub#
}#
#
# 2. Pad the plot list with blanks to force a 4x4 grid#
n_plots <- length(plot_list)#
if (n_plots < 16) {#
  for (i in (n_plots + 1):16) {#
    # Add a blank plot#
    plot_list[[i]] <- grid::nullGrob() #
  }#
}#
#
# 2. Arrange in a 4-column grid (which will now be 4x4)#
grid.arrange(#
  grobs = plot_list, #
  ncol = 4, #
  top = textGrob("Plot 4: Male Donor Y-Intensity by Dataset (Fixed Y-Axis)", #
                 gp = gpar(fontsize = 18, fontface = "bold")),#
  left = textGrob("Standardized Y Intensity", rot = 90, #
                 gp = gpar(fontsize = 16)),#
  bottom = textGrob("Donor (Sorted Low to High)", #
                 gp = gpar(fontsize = 16))#
)#
# ---#
# Close the PDF file#
# ---#
dev.off()#
#
message(paste("\nAll processing complete. 4 plot pages saved to:", output_pdf))

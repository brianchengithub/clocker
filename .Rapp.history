disease_definitions <- list(#
  list(name = "Hypertension",              var = "BPQ020",  table = "BPQ"),#
  list(name = "High_Cholesterol",          var = "BPQ080",  table = "BPQ"),#
  list(name = "Arthritis",                 var = "MCQ160A", table = "MCQ"),#
  list(name = "Coronary_Artery_Disease",   var = "MCQ160C", table = "MCQ"),#
  list(name = "Stroke",                    var = "MCQ160F", table = "MCQ"),#
  list(name = "Diabetes",                  var = "DIQ010",  table = "DIQ"),#
  list(name = "COPD",                      var = "MCQ160O", table = "MCQ"),#
  list(name = "Cancer",                    var = "MCQ220",  table = "MCQ")#
)#
#
# 2. Download and Merge Data#
# To handle text-based factors correctly, we set an option for the nhanesA package#
options(nhanesA.translation = "character") # Download data as character, not factors#
#
data_cycles <- c("H", "I", "J") # 2013-14, 2015-16, 2017-18#
all_data <- list()#
for (cycle in data_cycles) {#
  cat(paste("\n--- Processing Cycle", cycle, "---\n"))#
  dem_data <- nhanes(paste0("DEMO_", cycle)) %>% select(SEQN, SDMVPSU, SDMVSTRA, WTMEC2YR, RIDAGEYR)#
  quest_data_list <- lapply(disease_definitions, function(disease) {#
    table_to_fetch <- paste0(disease$table, "_", cycle)#
    tryCatch({#
      nhanes(table_to_fetch) %>% select(SEQN, one_of(disease$var))#
    }, error = function(e) { message(paste("--> WARNING: Could not find", disease$name, "in cycle", cycle)); return(NULL) })#
  })#
  bmx_data <- tryCatch(nhanes(paste0("BMX_", cycle)) %>% select(SEQN, BMXBMI), error=function(e) NULL)#
  all_tables_for_cycle <- c(list(dem_data), quest_data_list, list(bmx_data))#
  valid_tables <- purrr::compact(all_tables_for_cycle)#
  cycle_data <- reduce(valid_tables, full_join, by = "SEQN")#
  all_data[[cycle]] <- cycle_data#
}#
nhanes_data <- bind_rows(all_data)#
#
# 3. Data Cleaning and Variable Creation#
analysis_data <- nhanes_data#
#
# Use a simple, clear for-loop to create each binary disease variable.#
for (disease in disease_definitions) {#
  new_col_name <- disease$name#
  source_col_name <- disease$var#
  # *** THE DEFINITIVE FIX, BASED ON YOUR NEW INFORMATION ***#
  # Use case_when() to accurately code based on the text values "Yes" and "No".#
  # Everything else ("Don't know", "Refused", etc.) becomes NA and is properly excluded.#
  analysis_data[[new_col_name]] <- case_when(#
    analysis_data[[source_col_name]] == "Yes" ~ 1,#
    analysis_data[[source_col_name]] == "No"  ~ 0,#
    TRUE ~ NA_real_ # This codes all other responses as NA#
  )#
}#
#
# Create the Obesity variable, allowing for NAs in the source BMI data#
analysis_data$Obesity <- if_else(analysis_data$BMXBMI >= 30, 1, 0)#
# 4. Select final data and apply survey design#
diseases_to_plot <- c(map_chr(disease_definitions, ~.x$name), "Obesity")#
#
final_data <- analysis_data %>%#
  select(SEQN, SDMVPSU, SDMVSTRA, WTMEC2YR, RIDAGEYR, all_of(diseases_to_plot)) %>%#
  filter(RIDAGEYR >= 20) #
#
nhanes_design <- svydesign(#
  id = ~SDMVPSU,#
  strata = ~SDMVSTRA,#
  weights = ~WTMEC2YR,#
  data = final_data,#
  nest = TRUE#
)#
#
# 5. Calculate Prevalence#
# The `na.rm = TRUE` in `svymean` will now correctly handle the NAs we created.#
prevalence_data <- list()#
for (disease in diseases_to_plot) {#
  prev_by_age <- svyby(#
    formula = as.formula(paste0("~", disease)),#
    by = ~RIDAGEYR,#
    design = nhanes_design,#
    FUN = svymean,#
    na.rm = TRUE # This correctly handles the NAs for "Don't know", etc.#
  )#
  colnames(prev_by_age) <- c("RIDAGEYR", "Prevalence", "SE")#
  prev_by_age$Disease <- disease#
  prevalence_data[[disease]] <- prev_by_age#
}#
#
plot_data <- bind_rows(prevalence_data) %>%#
  rename(Age = RIDAGEYR)#
#
# 6. Create the Line Graph#
ggplot(plot_data, aes(x = Age, y = Prevalence, color = Disease)) +#
  geom_smooth(method = "loess", se = FALSE, aes(group = Disease), span = 0.75) +#
  labs(#
    title = "Prevalence of Common Chronic Diseases by Age in the USA",#
    subtitle = "Data from NHANES 2013-2018",#
    x = "Age (Years)",#
    y = "Prevalence",#
    color = "Chronic Disease"#
  ) +#
  scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +#
  theme_minimal() +#
  theme(#
    plot.title = element_text(hjust = 0.5, face = "bold"),#
    plot.subtitle = element_text(hjust = 0.5),#
    legend.position = "bottom"#
  ) +#
  guides(color = guide_legend(nrow = 2))
# 1. Define the chronic diseases, adding 'Anemia' and removing 'Obesity'.#
disease_definitions <- list(#
  list(name = "Hypertension",              var = "BPQ020",  table = "BPQ"),#
  list(name = "High_Cholesterol",          var = "BPQ080",  table = "BPQ"),#
  list(name = "Anemia",                    var = "MCQ160B", table = "MCQ"), # Added Anemia#
  list(name = "Arthritis",                 var = "MCQ160A", table = "MCQ"),#
  list(name = "Coronary_Artery_Disease",   var = "MCQ160C", table = "MCQ"),#
  list(name = "Stroke",                    var = "MCQ160F", table = "MCQ"),#
  list(name = "Diabetes",                  var = "DIQ010",  table = "DIQ"),#
  list(name = "COPD",                      var = "MCQ160G", table = "MCQ"),#
  list(name = "Cancer",                    var = "MCQ220",  table = "MCQ")#
)#
#
# 2. Download and Merge Data#
# To handle text-based factors correctly, we set an option for the nhanesA package#
options(nhanesA.translation = "character") # Download data as character, not factors#
#
data_cycles <- c("H", "I", "J") # 2013-14, 2015-16, 2017-18#
all_data <- list()#
for (cycle in data_cycles) {#
  cat(paste("\n--- Processing Cycle", cycle, "---\n"))#
  dem_data <- nhanes(paste0("DEMO_", cycle)) %>% select(SEQN, SDMVPSU, SDMVSTRA, WTMEC2YR, RIDAGEYR)#
  quest_data_list <- lapply(disease_definitions, function(disease) {#
    table_to_fetch <- paste0(disease$table, "_", cycle)#
    tryCatch({#
      nhanes(table_to_fetch) %>% select(SEQN, one_of(disease$var))#
    }, error = function(e) { message(paste("--> WARNING: Could not find", disease$name, "in cycle", cycle)); return(NULL) })#
  })#
  # Removed BMX (Obesity) data download#
  all_tables_for_cycle <- c(list(dem_data), quest_data_list)#
  valid_tables <- purrr::compact(all_tables_for_cycle)#
  cycle_data <- reduce(valid_tables, full_join, by = "SEQN")#
  all_data[[cycle]] <- cycle_data#
}#
nhanes_data <- bind_rows(all_data)#
#
# 3. Data Cleaning and Variable Creation#
analysis_data <- nhanes_data#
#
# Use a simple, clear for-loop to create each binary disease variable.#
for (disease in disease_definitions) {#
  new_col_name <- disease$name#
  source_col_name <- disease$var#
  # Use case_when() to accurately code based on the text values "Yes" and "No".#
  analysis_data[[new_col_name]] <- case_when(#
    analysis_data[[source_col_name]] == "Yes" ~ 1,#
    analysis_data[[source_col_name]] == "No"  ~ 0,#
    TRUE ~ NA_real_ # This codes all other responses as NA#
  )#
}#
#
# Removed the Obesity calculation line#
#
# 4. Select final data and apply survey design#
diseases_to_plot <- map_chr(disease_definitions, ~.x$name) # No longer need to add "Obesity"#
#
final_data <- analysis_data %>%#
  select(SEQN, SDMVPSU, SDMVSTRA, WTMEC2YR, RIDAGEYR, all_of(diseases_to_plot)) %>%#
  filter(RIDAGEYR >= 20) #
#
nhanes_design <- svydesign(#
  id = ~SDMVPSU,#
  strata = ~SDMVSTRA,#
  weights = ~WTMEC2YR,#
  data = final_data,#
  nest = TRUE#
)#
#
# 5. Calculate Prevalence#
prevalence_data <- list()#
for (disease in diseases_to_plot) {#
  prev_by_age <- svyby(#
    formula = as.formula(paste0("~", disease)),#
    by = ~RIDAGEYR,#
    design = nhanes_design,#
    FUN = svymean,#
    na.rm = TRUE#
  )#
  colnames(prev_by_age) <- c("RIDAGEYR", "Prevalence", "SE")#
  prev_by_age$Disease <- disease#
  prevalence_data[[disease]] <- prev_by_age#
}#
#
plot_data <- bind_rows(prevalence_data) %>%#
  rename(Age = RIDAGEYR)#
#
# 6. Create the Line Graph#
ggplot(plot_data, aes(x = Age, y = Prevalence, color = Disease)) +#
  geom_smooth(method = "loess", se = FALSE, aes(group = Disease), span = 0.75) +#
  labs(#
    title = "Prevalence of Common Chronic Diseases by Age in the USA",#
    subtitle = "Data from NHANES 2013-2018",#
    x = "Age (Years)",#
    y = "Prevalence",#
    color = "Chronic Disease"#
  ) +#
  # Set y-axis to go from 0% to 100%#
  scale_y_continuous(labels = scales::percent_format(accuracy = 1), limits = c(0, 1)) +#
  theme_minimal() +#
  theme(#
    plot.title = element_text(hjust = 0.5, face = "bold"),#
    plot.subtitle = element_text(hjust = 0.5),#
    legend.position = "bottom"#
  ) +#
  guides(color = guide_legend(nrow = 2))

path2 = "/Users/bc/Downloads/GSE54758_unmethylated_and_methylated.txt.gz"#
betas = readr::read_tsv(path2)
betas = as.data.frame(betas)
betas[1:5,1:6]
temp <- betas
# Split M vs U into separate dataframes#
Mcols = grep("Methylated",   names(temp))#
Ucols = grep("Unmethylated", names(temp))#
#
datM = temp[,Mcols]#
datU = temp[,Ucols]#
#
rownames(datM) = temp$ID_REF#
rownames(datU) = temp$ID_REF
# Create sequence of column indices#
columns <- seq_len(ncol(datM))#
#
# Apply parseGEOsignalMU to each column #
sdfs <- lapply(columns, function(col) {#
  parseGEOsignalMU(sigM=datM[,col], sigU=datU[,col], Probe_IDs=rownames(datM))#
})#
#
# "sdfs" (list) goes into openSesame#
betas <- openSesame(sdfs, prep="QCDPB", func=getBetas)#
#
# Apply column names to beta matrix#
colnames(betas) <- gsub("_.*", "", names(datU))
b450 <- betas
rm(betas)
ls()
sdf450<- sdfs
rm(sdfs)
rm(list=c("columns", "datM", "datU", "Mcols", "path2", "temp", "Ucols"))
gc()
ls()

if (!require("pwr")) install.packages("pwr")
library(pwr)
library(ggplot2)#
library(dplyr)
# --- 2. DEFINE PARAMETERS ---#
# Set the parameters for the power analysis#
effect_sizes_int <- 1:5       # Integer effect sizes (Cohen's d)#
power_level <- 0.80          # Desired statistical power (80%)#
alpha_level <- 0.50          # Significance level (alpha). Note: 0.5 is highly unconventional.#
test_type <- "two.sample"    # Type of t-test#
alt_hyp <- "two.sided"       # Two-sided hypothesis#
#
# --- 3. CALCULATE SAMPLE SIZES ---#
# Create an empty data frame to store results#
results_df <- data.frame(#
  EffectSize = numeric(),#
  SampleSizePerGroup = numeric()#
)
# --- 2. DEFINE PARAMETERS ---#
# Set the parameters for the power analysis#
effect_sizes_int <- 1:5       # Integer effect sizes (Cohen's d)#
power_level <- 0.80          # Desired statistical power (80%)#
alpha_level <- 0.05          # Significance level (alpha).  #
test_type <- "two.sample"    # Type of t-test#
alt_hyp <- "two.sided"       # Two-sided hypothesis#
#
# --- 3. CALCULATE SAMPLE SIZES ---#
# Create an empty data frame to store results#
results_df <- data.frame(#
  EffectSize = numeric(),#
  SampleSizePerGroup = numeric()#
)
# Loop through each integer effect size to calculate the required sample size#
for (d in effect_sizes_int) {#
  # Use pwr.t.test to solve for n (sample size per group)#
  pwr_result <- pwr.t.test(#
    d = d,#
    sig.level = alpha_level,#
    power = power_level,#
    type = test_type,#
    alternative = alt_hyp#
  )#
  # Create a temporary data frame for the current result#
  temp_df <- data.frame(#
    EffectSize = d,#
    SampleSizePerGroup = ceiling(pwr_result$n) # Round up to the next whole number#
  )#
  # Add the result to the main data frame#
  results_df <- rbind(results_df, temp_df)#
}
# --- 4. DISPLAY RESULTS TABLE ---#
# Print the calculated sample sizes#
cat("Required Sample Size Per Group:\n")#
print(results_df)
# --- 5. PREPARE DATA FOR PLOTTING ---#
# Create a continuous sequence of effect sizes for a smooth plot line#
d_continuous <- seq(1, 5, by = 0.1)#
#
# Calculate sample sizes for the continuous range#
n_continuous <- sapply(d_continuous, function(d) {#
  pwr_result <- pwr.t.test(#
    d = d,#
    sig.level = alpha_level,#
    power = power_level,#
    type = test_type,#
    alternative = alt_hyp#
  )#
  return(pwr_result$n)#
})#
#
# Combine into a data frame for plotting#
plot_df <- data.frame(EffectSize = d_continuous, SampleSizePerGroup = n_continuous)
# --- 6. GENERATE PLOT ---#
# Create the plot using ggplot2#
# The prompt's request for "a different colored line for each integer" is best visualized#
# by plotting a single curve and highlighting the specific integer points.#
sample_size_plot <- ggplot() +#
  # Plot the continuous line#
  geom_line(data = plot_df, aes(x = EffectSize, y = SampleSizePerGroup), color = "#0072B2", linewidth = 1) +#
  # Add points for the integer effect sizes calculated earlier#
  geom_point(data = results_df, aes(x = EffectSize, y = SampleSizePerGroup), color = "#D55E00", size = 4) +#
  # Add text labels for the points#
  geom_text(#
    data = results_df,#
    aes(x = EffectSize, y = SampleSizePerGroup, label = SampleSizePerGroup),#
    vjust = -1.2, # Adjust vertical position to be above the point#
    fontface = "bold",#
    color = "black"#
  ) +#
  labs(#
    title = "Sample Size by Effect Size",#
    subtitle = paste0("For Power = ", power_level, " and Alpha = ", alpha_level),#
    x = "Effect Size (Cohen's d)",#
    y = "Required Sample Size (n) Per Group"#
  ) +#
  scale_y_continuous(limits = c(0, max(results_df$SampleSizePerGroup) * 1.2)) + # Ensure space for labels#
  theme_minimal(base_size = 14)#
#
# Print the plot#
print(sample_size_plot)
q()

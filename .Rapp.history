library(GEOquery)#
library(dplyr)#
# Manually download beta matrix#
# https://www.ncbi.nlm.nih.gov/geo/download/?acc=GSE184410&format=file&file=GSE184410%5F20210916%5FGEO%5Fsignal%5Fintensity%5Fmatrix%2Ecsv%2Egz#
# Parse GEO series matrix file (for metadata)#
#
parse_geo_series_matrix <- function(geo_accession) {#
  # Download and parse the GEO series matrix file#
  geo_data <- getGEO(geo_accession, GSEMatrix = TRUE, AnnotGPL = FALSE)#
  # Extract the metadata from the GEO object#
  metadata_list <- pData(phenoData(geo_data[[1]]))#
  # Convert the metadata to a dataframe#
  metadata_df <- as.data.frame(metadata_list)#
  return(metadata_df)#
}#
#
# Run function#
geo_accession <- "GSE184410"  #
metadf <- parse_geo_series_matrix(geo_accession)#
#
# Display the first few rows of the metadata dataframe#
head(metadf)#
#
# See all strains#
table(metadf$characteristics_ch1.3, exclude=NULL)#
#
# List of C57BL strains#
c57 = c(#
"strain: C57BL/10J",#
"strain: C57BL/6J",#
"strain: C57BL/6NJ",#
"strain: C57L/J")#
#
# Subset metadata to C57BL#
metadf = subset(metadf, characteristics_ch1.3 %in% c57)
dim(metadf)
metadf[1:5,1:5]
metadf[1:3,]
dfu = dfu[,metadf$description.1]
dim(dfu)
dim(dfm)
dfm = dfm[,metadf$description.1]
dim(dfm)
rm(b); gc();
identical(names(dfu), names(dfm))
identical(dim(dfu), dim(dfm))
datU = dfU
datU = dfu
datM = dfm
sdfs = list()#

library(survey)#
library(nhanesA)
find_most_recent_nhanes_cycle <- function() {#
  current_year <- as.numeric(format(Sys.Date(), "%Y"))#
  # NHANES data is released in 2-year cycles, starting with odd years#
  for (year in seq(from = current_year, to = 1999, by = -1)) {#
    # We only need to check for odd years as they mark the start of a cycle#
    if (year %% 2 != 0) {#
      cat("Checking for NHANES data in", year, "-", year + 1, "cycle...\n")#
      # Use a tryCatch to handle cases where a year is not found gracefully#
      tables <- try(nhanesTables(data_group = 'DEMO', year = year), silent = TRUE)#
      if (!inherits(tables, "try-error") && nrow(tables) > 0) {#
        cat("Found the most recent available data cycle: ", year, "-", year + 1, "\n")#
        return(paste0(year, "-", year + 1))#
      }#
    }#
  }#
  return("No NHANES data cycles found.")#
}#
#
# Run the function to find the most recent cycle#
most_recent_cycle <- find_most_recent_nhanes_cycle()
find_most_recent_nhanes_cycle <- function() {#
  # Get the current year#
  current_year <- as.numeric(format(Sys.Date(), "%Y"))#
  # NHANES data is released in 2-year cycles. We loop backwards from the current year.#
  # We check for the starting year of each cycle (typically an odd year).#
  for (year in seq(from = current_year, to = 1999, by = -1)) {#
    if (year %% 2 != 0) { # NHANES cycles start on odd years (1999, 2001, etc.)#
      cat("Checking for NHANES data in", year, "-", year + 1, "cycle...\n")#
      # Use tryCatch to gracefully handle potential internet connection errors#
      tables <- try(nhanesTables(data_group = 'DEMO', year = year), silent = TRUE)#
      # *** CORRECTED LOGIC ***#
      # Check if the returned object is a valid, non-empty data frame#
      if (!inherits(tables, "try-error") && !is.null(tables) && is.data.frame(tables) && nrow(tables) > 0) {#
        cat("\nSUCCESS: Found the most recent available data cycle:", year, "-", year + 1, "\n")#
        return(paste0(year, "-", year + 1))#
      }#
    }#
  }#
  return("No NHANES data cycles were found.")#
}#
#
# Run the function to find the most recent cycle#
most_recent_cycle <- find_most_recent_nhanes_cycle()#
#
print(paste("The most recent full cycle available is:", most_recent_cycle))
# 1. Define the chronic diseases and corresponding NHANES variables#
# NOTE: We only need the general cancer question now (MCQ220)#
disease_vars <- list(#
  "Hypertension" = "BPQ020",      # Ever told you had high blood pressure#
  "High_Cholesterol" = "BPQ080",  # Ever told you had high cholesterol#
  "Arthritis" = "MCQ160a",        # Ever told you had arthritis#
  "Coronary_Artery_Disease" = "MCQ160c", # Ever told you had coronary heart disease#
  "Stroke" = "MCQ160f",           # Ever told you had a stroke#
  "Diabetes" = "DIQ010",          # Ever told you had diabetes#
  "COPD" = "MCQ160o",             # Ever told you had COPD#
  "Depression" = "DPQ020",        # Ever told you had depression (using a proxy from PHQ-9)#
  "Cancer" = "MCQ220"             # Ever had cancer or malignancy of any kind#
)#
#
# Obesity will be calculated from BMI.#
#
# 2. Download NHANES data for multiple cycles for a larger sample size#
# We'll use data from 2013-2014, 2015-2016, and 2017-2018 for robustness.#
data_cycles <- c("H", "I", "J") # Corresponds to 2013-14, 2015-16, 2017-18#
#
all_data <- list()#
#
for (cycle in data_cycles) {#
  # Demographics#
  dem_data <- nhanes(paste0("DEMO_", cycle)) %>%#
    select(SEQN, SDMVPSU, SDMVSTRA, WTMEC2YR, RIDAGEYR)#
#
  # Questionnaire data#
  quest_data_list <- lapply(names(disease_vars), function(disease) {#
    table_name <- sub("_.+$", "", disease_vars[[disease]])#
    tryCatch({#
      nhanes(paste0(table_name, "_", cycle)) %>%#
        select(SEQN, one_of(disease_vars[[disease]]))#
    }, error = function(e) {#
      message(paste("Could not find", disease, "data for cycle", cycle))#
      return(NULL)#
    })#
  })#
#
  # Body Measures for Obesity#
  bmx_data <- nhanes(paste0("BMX_", cycle)) %>%#
    select(SEQN, BMXBMI)#
#
  # Merge all data for the cycle#
  cycle_data <- reduce(c(list(dem_data), quest_data_list), full_join, by = "SEQN")#
  # Add BMX data separately as it might have fewer rows#
  cycle_data <- full_join(cycle_data, bmx_data, by = "SEQN")#
  all_data[[cycle]] <- cycle_data#
}#
#
# Combine data from all cycles#
nhanes_data <- bind_rows(all_data)#
#
# 3. Data Cleaning and Variable Creation#
#
# Create binary disease variables (1 = Yes, 0 = No)#
nhanes_data <- nhanes_data %>%#
  mutate(#
    Hypertension = if_else(BPQ020 == 1, 1, 0, missing = 0),#
    High_Cholesterol = if_else(BPQ080 == 1, 1, 0, missing = 0),#
    Arthritis = if_else(MCQ160a == 1, 1, 0, missing = 0),#
    Coronary_Artery_Disease = if_else(MCQ160c == 1, 1, 0, missing = 0),#
    Stroke = if_else(MCQ160f == 1, 1, 0, missing = 0),#
    Diabetes = if_else(DIQ010 == 1, 1, 0, missing = 0),#
    COPD = if_else(MCQ160g == 1, 1, 0, missing = 0),#
    Depression = if_else(DPQ020 > 0, 1, 0, missing = 0), # Simplified depression proxy#
    Obesity = if_else(BMXBMI >= 30, 1, 0, missing = 0),#
    Cancer = if_else(MCQ220 == 1, 1, 0, missing = 0)#
  )#
#
# Select final variables for analysis#
final_data <- nhanes_data %>%#
  select(SEQN, SDMVPSU, SDMVSTRA, WTMEC2YR, RIDAGEYR,#
         Hypertension, High_Cholesterol, Arthritis, Coronary_Artery_Disease,#
         Stroke, Diabetes, COPD, Depression, Obesity, Cancer) %>% # "Melanoma" removed#
  filter(RIDAGEYR >= 20) # Focus on adults#
#
# 4. Apply Survey Weighting#
#
nhanes_design <- svydesign(#
  id = ~SDMVPSU,#
  strata = ~SDMVSTRA,#
  weights = ~WTMEC2YR,#
  data = final_data,#
  nest = TRUE#
)#
# 5. Calculate Age-Specific Prevalence for each disease#
#
diseases_to_plot <- c("Hypertension", "Obesity", "High_Cholesterol", "Arthritis", #
                       "Coronary_Artery_Disease", "Diabetes", "Stroke", "Cancer", #
                       "COPD", "Depression") # "Melanoma" removed#
#
prevalence_data <- list()#
#
for (disease in diseases_to_plot) {#
  # Calculate weighted prevalence by age#
  prev_by_age <- svyby(#
    formula = as.formula(paste0("~", disease)),#
    by = ~RIDAGEYR,#
    design = nhanes_design,#
    FUN = svymean,#
    na.rm = TRUE#
  )#
#
  prev_by_age$Disease <- disease#
  # Clean up column names after svyby#
  prev_by_age <- prev_by_age %>%#
    select(RIDAGEYR, Prevalence = one_of(disease), SE = one_of(paste0("se.", disease)), Disease)#
  prevalence_data[[disease]] <- prev_by_age#
}#
#
# Combine prevalence data into a single data frame#
plot_data <- bind_rows(prevalence_data) %>%#
  rename(Age = RIDAGEYR)#
#
# 6. Create the Line Graph#
#
ggplot(plot_data, aes(x = Age, y = Prevalence, color = Disease)) +#
  geom_smooth(method = "loess", se = FALSE, aes(group = Disease), span = 0.75) + # Use loess smoothing#
  labs(#
    title = "Prevalence of Common Chronic Diseases by Age in the USA",#
    subtitle = "Data from NHANES 2013-2018",#
    x = "Age (Years)",#
    y = "Prevalence",#
    color = "Chronic Disease"#
  ) +#
  scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +#
  theme_minimal() +#
  theme(#
    plot.title = element_text(hjust = 0.5, face = "bold"),#
    plot.subtitle = element_text(hjust = 0.5),#
    legend.position = "bottom"#
  ) +#
  guides(color = guide_legend(nrow = 2)) # Adjust legend for better readability
# 1. Define the chronic diseases, their variables, AND their table names explicitly.#
# This is the key change to prevent download errors.#
disease_definitions <- list(#
  list(name = "Hypertension",              var = "BPQ020",  table = "BPQ"),#
  list(name = "High_Cholesterol",          var = "BPQ080",  table = "BPQ"),#
  list(name = "Arthritis",                 var = "MCQ160a", table = "MCQ"),#
  list(name = "Coronary_Artery_Disease",   var = "MCQ160c", table = "MCQ"),#
  list(name = "Stroke",                    var = "MCQ160f", table = "MCQ"),#
  list(name = "Diabetes",                  var = "DIQ010",  table = "DIQ"),#
  list(name = "COPD",                      var = "MCQ160o", table = "MCQ"),#
  list(name = "Cancer",                    var = "MCQ220",  table = "MCQ")#
  # Note: Depression (DPQ) and Obesity (BMX) will be handled separately due to different logic.#
)#
#
# We'll use data from 2013-2014, 2015-2016, and 2017-2018.#
data_cycles <- c("H", "I", "J") # Corresponds to 2013-14, 2015-16, 2017-18#
#
all_data <- list()#
#
for (cycle in data_cycles) {#
  cat(paste("\n--- Processing Cycle", cycle, "(" , nhanesCycleYears(cycle), ") ---\n"))#
  # A. Demographics (always needed)#
  dem_data <- nhanes(paste0("DEMO_", cycle)) %>%#
    select(SEQN, SDMVPSU, SDMVSTRA, WTMEC2YR, RIDAGEYR)#
#
  # B. Questionnaire data based on our robust definitions#
  quest_data_list <- lapply(disease_definitions, function(disease) {#
    table_to_fetch <- paste0(disease$table, "_", cycle)#
    cat(paste("Fetching", disease$name, "from table", table_to_fetch, "...\n"))#
    tryCatch({#
      nhanes(table_to_fetch) %>% select(SEQN, one_of(disease$var))#
    }, error = function(e) {#
      message(paste("--> WARNING: Could not find or download data for", disease$name, "in cycle", cycle))#
      return(NULL) # Return NULL on failure#
    })#
  })#
#
  # C. Special tables: Depression (DPQ) and Body Measures (BMX)#
  dpq_data <- tryCatch(nhanes(paste0("DPQ_", cycle)) %>% select(SEQN, DPQ020), error=function(e) NULL)#
  bmx_data <- tryCatch(nhanes(paste0("BMX_", cycle)) %>% select(SEQN, BMXBMI), error=function(e) NULL)#
#
  # D. Robustly merge all downloaded tables#
  # Combine all data frames into one list and remove any NULLs from download failures#
  all_tables_for_cycle <- c(list(dem_data), quest_data_list, list(dpq_data), list(bmx_data))#
  valid_tables <- purrr::compact(all_tables_for_cycle)#
  # Use reduce to sequentially join all valid tables#
  cycle_data <- reduce(valid_tables, full_join, by = "SEQN")#
  all_data[[cycle]] <- cycle_data#
}#
#
# Combine data from all cycles#
nhanes_data <- bind_rows(all_data)#
#
# 3. Data Cleaning and Variable Creation#
nhanes_data <- nhanes_data %>%#
  mutate(#
    # Loop through our definitions to create binary disease variables#
    !!!setNames(map(disease_definitions, ~if_else(nhanes_data[[.x$var]] == 1, 1, 0, missing = 0)), #
                 map_chr(disease_definitions, ~.x$name)),#
    # Handle special cases#
    Depression = if_else(DPQ020 > 0 & DPQ020 < 7, 1, 0, missing = 0), # Using a common definition for MDE#
    Obesity = if_else(BMXBMI >= 30, 1, 0, missing = 0)#
  )#
#
# Select final variables for analysis#
diseases_to_plot <- c(map_chr(disease_definitions, ~.x$name), "Depression", "Obesity")#
#
final_data <- nhanes_data %>%#
  select(SEQN, SDMVPSU, SDMVSTRA, WTMEC2YR, RIDAGEYR, all_of(diseases_to_plot)) %>%#
  filter(RIDAGEYR >= 20) # Focus on adults#
#
# 4. Apply Survey Weighting#
nhanes_design <- svydesign(#
  id = ~SDMVPSU,#
  strata = ~SDMVSTRA,#
  weights = ~WTMEC2YR,#
  data = final_data,#
  nest = TRUE#
)#
#
# 5. Calculate Age-Specific Prevalence for each disease#
prevalence_data <- list()#
for (disease in diseases_to_plot) {#
  prev_by_age <- svyby(#
    formula = as.formula(paste0("~", disease)),#
    by = ~RIDAGEYR,#
    design = nhanes_design,#
    FUN = svymean,#
    na.rm = TRUE#
  )#
  prev_by_age$Disease <- disease#
  prev_by_age <- prev_by_age %>%#
    select(RIDAGEYR, Prevalence = one_of(disease), SE = one_of(paste0("se.", disease)), Disease)#
  prevalence_data[[disease]] <- prev_by_age#
}#
#
plot_data <- bind_rows(prevalence_data) %>%#
  rename(Age = RIDAGEYR)#
#
# 6. Create the Line Graph#
ggplot(plot_data, aes(x = Age, y = Prevalence, color = Disease)) +#
  geom_smooth(method = "loess", se = FALSE, aes(group = Disease), span = 0.75) +#
  labs(#
    title = "Prevalence of Common Chronic Diseases by Age in the USA",#
    subtitle = "Data from NHANES 2013-2018",#
    x = "Age (Years)",#
    y = "Prevalence",#
    color = "Chronic Disease"#
  ) +#
  scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +#
  theme_minimal() +#
  theme(#
    plot.title = element_text(hjust = 0.5, face = "bold"),#
    plot.subtitle = element_text(hjust = 0.5),#
    legend.position = "bottom"#
  ) +#
  guides(color = guide_legend(nrow = 2))
